---
---

<section class="logos-v2 reveal">
	<div class="container">
		<p class="logo-label">CREDIBILITY_NETWORK</p>
		<div class="logo-grid">
			<!-- Carta -->
			<div class="logo-item">
				<svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
					<path d="M50 0L100 50L50 100L0 50L50 0Z" fill="currentColor"/>
				</svg>
				<span>Carta</span>
			</div>
			
			<!-- Descript -->
			<div class="logo-item">
				<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z" fill="currentColor"/>
					<circle cx="12" cy="12" r="5" fill="currentColor"/>
				</svg>
				<span>Descript</span>
			</div>

			<!-- OpenSea -->
			<div class="logo-item">
				<svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
					<path d="M20 0C8.954 0 0 8.954 0 20s8.954 20 20 20 20-8.954 20-20S31.046 0 20 0zm10.5 25.5l-10.5 6-10.5-6V14.5l10.5-6 10.5 6v11z" fill="currentColor"/>
				</svg>
				<span>OpenSea</span>
			</div>

			<!-- Asana -->
			<div class="logo-item">
				<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<circle cx="12" cy="7" r="3" fill="currentColor"/>
					<circle cx="7" cy="16" r="3" fill="currentColor"/>
					<circle cx="17" cy="16" r="3" fill="currentColor"/>
				</svg>
				<span>Asana</span>
			</div>

			<!-- Dropbox -->
			<div class="logo-item">
				<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path d="M6 2l6 4-6 4-6-4 6-4zm12 0l6 4-6 4-6-4 6-4zM0 10l6 4 6-4-6-4-6 4zm24 0l-6 4-6-4 6-4 6 4zM6 14l6 4 6-4-6-4-6 4z" fill="currentColor"/>
				</svg>
				<span>Dropbox</span>
			</div>

			<!-- Moonvalley (Stylized Icon) -->
			<div class="logo-item">
				<svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
					<circle cx="50" cy="50" r="40" stroke="currentColor" stroke-width="8" fill="none" stroke-dasharray="180 60"/>
					<circle cx="50" cy="50" r="15" fill="currentColor"/>
				</svg>
				<span>Moonvalley</span>
			</div>

			<!-- Invisible Technologies -->
			<div class="logo-item">
				<svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
					<path d="M20 20L50 80L80 20" stroke="currentColor" stroke-width="12" fill="none" stroke-linecap="round"/>
				</svg>
				<span>Invisible</span>
			</div>
		</div>
	</div>
</section>

<style>
	.logos-v2 {
		padding: 4rem 0;
		border-top: 1px solid var(--border-light);
		border-bottom: 1px solid var(--border-light);
		background: #FFF;
	}

	.logo-label {
		font-size: 0.6rem;
		font-weight: 800;
		letter-spacing: 0.2rem;
		color: var(--p-gray);
		text-align: center;
		margin-bottom: 3rem;
	}

	.logo-grid {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 4rem;
		align-items: center;
	}

	.logo-item {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		color: var(--p-gray);
		filter: grayscale(1);
		opacity: 0.6;
		transition: all 0.4s ease;
	}

	.logo-item svg {
		width: 24px;
		height: 24px;
	}

	.logo-item span {
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.05rem;
		text-transform: uppercase;
	}

	.logo-item:hover {
		filter: grayscale(0);
		opacity: 1;
		color: var(--fg-warm-black);
		transform: translateY(-2px);
	}

	@media (max-width: 768px) {
		.logo-grid { gap: 2rem; }
	}
</style>
