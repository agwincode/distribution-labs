---
---

<section id="team" class="team">
	<div class="container">

		<div class="team-intro reveal">
			<p class="section-label">THE OPERATORS</p>
			<h2 class="team-headline">Make your marketing org<br><em>your secret weapon</em></h2>
			<p class="team-lead">We're former SVPs and GMs from Carta, Asana, Descript, and OpenSea. We've run marketing at scale. We step in at CMO-level: so you don't lose a single day of growth.</p>
		</div>

		<div class="team-grid">

			<div class="member reveal">
				<div class="member-photo">
					<img src="/angela.jpeg" alt="Angela Winegar" width="400" height="400" loading="lazy" />
				</div>
				<h3 class="member-name">Angela Winegar</h3>
				<p class="member-title">SVP of Marketing & Strategy</p>
				<p class="member-prev">Invisible Technologies, Carta</p>
				<p class="member-stat">Grew Carta from ~$100M to ~$500M revenue</p>
			</div>

			<div class="member reveal">
				<div class="member-photo">
					<img src="/sarah.jpeg" alt="Sarah Charlton" width="400" height="400" loading="lazy" />
				</div>
				<h3 class="member-name">Sarah Charlton</h3>
				<p class="member-title">GM Global Growth</p>
				<p class="member-prev">Asana, Moonvalley AI, Dropbox</p>
				<p class="member-stat">Scaled Asana self-serve from &lt;$25M through IPO</p>
			</div>

			<div class="member reveal">
				<div class="member-photo">
					<img src="/whitney.jpeg" alt="Whitney Steele" width="400" height="400" loading="lazy" />
				</div>
				<h3 class="member-name">Whitney Steele</h3>
				<p class="member-title">VP Marketing</p>
				<p class="member-prev">Descript, OpenSea</p>
			</div>

		</div>

	</div>
</section>

<style>
	.team {
		background: var(--black);
		padding: 8rem 0 9rem;
		border-top: 1px solid var(--border);
	}

	/* ── Intro ────────────────────────────────── */
	.team-intro {
		margin-bottom: 5rem;
	}

	.section-label {
		font-family: var(--font-display);
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.28em;
		color: var(--orange);
		margin-bottom: 1.5rem;
	}

	.team-headline {
		font-family: var(--font-headline);
		font-weight: 700;
		font-size: clamp(2rem, 3.5vw, 3rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin: 0 0 2rem;
		color: var(--white);
		max-width: 600px;
	}

	.team-headline em {
		font-style: normal;
		color: var(--sky);
	}

	.team-lead {
		font-family: var(--font-body);
		font-size: 1rem;
		font-weight: 400;
		color: rgba(237, 236, 227, 0.75);
		line-height: 1.75;
		max-width: 520px;
		margin: 0;
	}

	/* ── Grid ─────────────────────────────────── */
	.team-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 3rem;
	}

	/* ── Member card ──────────────────────────── */
	.member-photo {
		margin-bottom: 1.5rem;
		overflow: hidden;
		border-radius: 50%;
	}

	.member-photo img {
		width: 100%;
		aspect-ratio: 1;
		object-fit: cover;
		object-position: center 20%;
		border-radius: 50%;
		filter: grayscale(100%) contrast(1.1) brightness(0.9);
		transition: filter 0.6s ease;
		display: block;
	}

	.member:hover .member-photo img {
		filter: grayscale(0%) contrast(1) brightness(1);
	}

	.member-name {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1.1rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--white);
		margin: 0 0 0.4rem;
	}

	.member-title {
		font-family: var(--font-body);
		font-size: 0.82rem;
		font-weight: 500;
		color: var(--white);
		margin: 0 0 0.2rem;
		letter-spacing: 0.02em;
	}

	.member-prev {
		font-family: var(--font-body);
		font-size: 0.78rem;
		font-weight: 400;
		color: var(--muted);
		margin: 0 0 0.75rem;
		letter-spacing: 0.02em;
	}

	.member-stat {
		font-family: var(--font-body);
		font-size: 0.78rem;
		font-weight: 400;
		font-style: italic;
		color: var(--sky);
		opacity: 0.85;
		margin: 0;
		line-height: 1.5;
	}

	/* ── Responsive ───────────────────────────── */
	@media (max-width: 768px) {
		.team { padding: 5rem 0 6rem; }
		.team-intro { margin-bottom: 3rem; }
		.team-grid {
			grid-template-columns: 1fr;
			gap: 2.5rem;
		}
		.team-headline { font-size: clamp(1.75rem, 7vw, 2.5rem); }
	}

	@media (max-width: 480px) {
		.team { padding: 4rem 0 5rem; }
		.team-lead { font-size: 0.9rem; }
	}
</style>
