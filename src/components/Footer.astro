---
---

<footer id="contact" class="site-footer reveal">
	<div class="container">
		<div class="footer-inner">

			<div class="footer-left">
				<span class="footer-wordmark">DISTRIBUTION LABS</span>
				<p class="footer-copy">&copy; {new Date().getFullYear()} Distribution Labs. All rights reserved.</p>
			</div>

			<div class="footer-right">
				<a href="mailto:hello@distribution-labs.com" class="footer-email">hello@distribution-labs.com</a>
			</div>

		</div>
	</div>
</footer>

<style>
	.site-footer {
		background: var(--black);
		padding: 4rem 0;
		border-top: 1px solid var(--border);
	}

	.footer-inner {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.footer-wordmark {
		display: block;
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 0.8rem;
		letter-spacing: 0.28em;
		color: var(--white);
		margin-bottom: 0.65rem;
	}

	.footer-copy {
		font-family: var(--font-body);
		font-size: 0.75rem;
		color: var(--muted);
		margin: 0;
		opacity: 0.7;
	}

	.footer-email {
		font-family: var(--font-body);
		font-size: 0.82rem;
		color: var(--muted);
		text-decoration: none;
		padding-bottom: 2px;
		border-bottom: 1px solid transparent;
		transition: color 0.2s, border-color 0.2s;
	}
	.footer-email:hover {
		color: var(--white);
		border-color: var(--orange);
	}

	@media (max-width: 640px) {
		.footer-inner {
			flex-direction: column;
			gap: 2rem;
			text-align: center;
		}
	}
</style>
