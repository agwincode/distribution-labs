---
---

<footer id="contact" class="site-footer">
	<div class="container">

		<div class="footer-close reveal">
			<p class="close-line">The narrative is the strategy.</p>
			<a href="mailto:hello@distribution-labs.com" class="close-email">hello@distribution-labs.com</a>
		</div>

		<div class="footer-bottom">
			<span class="footer-wordmark">DISTRIBUTION LABS</span>
			<p class="footer-copy">&copy; {new Date().getFullYear()} Distribution Labs</p>
		</div>

	</div>
</footer>

<style>
	.site-footer {
		background: var(--black);
		padding: 0 0 3rem;
	}

	/* ── Closing moment ───────────────────────── */
	.footer-close {
		padding: 6rem 0;
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
		margin-bottom: 3rem;
	}

	.close-line {
		font-family: var(--font-display);
		font-weight: 900;
		font-size: clamp(2rem, 4vw, 3.2rem);
		text-transform: uppercase;
		line-height: 1;
		letter-spacing: -0.01em;
		color: var(--white);
		margin: 0 0 2rem;
	}

	.close-email {
		font-family: var(--font-body);
		font-size: 1rem;
		color: var(--muted);
		text-decoration: none;
		border-bottom: 1px solid rgba(255, 84, 2, 0.4);
		padding-bottom: 3px;
		transition: color 0.3s, border-color 0.3s;
	}
	.close-email:hover {
		color: var(--white);
		border-color: var(--orange);
	}

	/* ── Bottom bar ───────────────────────────── */
	.footer-bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.footer-wordmark {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 0.7rem;
		letter-spacing: 0.28em;
		color: var(--white);
		opacity: 0.4;
	}

	.footer-copy {
		font-family: var(--font-body);
		font-size: 0.72rem;
		color: var(--muted);
		margin: 0;
		opacity: 0.4;
	}

	@media (max-width: 640px) {
		.footer-close { padding: 4rem 0; }
		.footer-bottom {
			flex-direction: column;
			gap: 0.75rem;
			text-align: center;
		}
	}
</style>
