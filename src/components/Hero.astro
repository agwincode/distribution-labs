---
---

<section id="hero" class="hero">

	<video class="hero-video" autoplay muted loop playsinline poster="/trees.jpg" aria-hidden="true">
		<source src="/hero.mp4" type="video/mp4" />
	</video>

	<div class="container">

		<div class="hero-body reveal">

			<p class="eyebrow">GROWTH ADVISORY FOR FOUNDERS</p>

			<h1 class="display-h1">
				<span class="line line-1">Own the</span>
				<span class="line line-2">category</span>
				<span class="line line-3">before <em>someone</em></span>
				<span class="line line-4"><em>else does.</em></span>
			</h1>

			<p class="hero-sub">
				We help growth-stage founders build the engine
				that wins the market... before a competitor does it first.
			</p>

			<a href="#team" class="hero-cta">
				Meet the team
				<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
					<path d="M8 3v10M3 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
			</a>

		</div>
	</div>

	<div class="hero-scroll-rule" aria-hidden="true"></div>

</section>

<style>
	.hero {
		min-height: 90vh;
		display: flex;
		flex-direction: column;
		background: var(--white);
		position: relative;
		overflow: hidden;
	}

	.hero-video {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		opacity: 0.18;
		z-index: 0;
	}

	.container { position: relative; z-index: 1; }

	/* ── Nav ─────────────────────────────────── */
	.nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 2.25rem 0;
	}

	.wordmark {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 0.85rem;
		letter-spacing: 0.28em;
		color: var(--black);
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 2.5rem;
	}

	.nav-link {
		font-family: var(--font-body);
		font-size: 0.8rem;
		color: var(--black);
		text-decoration: none;
		letter-spacing: 0.05em;
		transition: color 0.2s;
	}
	.nav-link:hover { color: var(--black); }

	.nav-cta {
		font-family: var(--font-display);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--black);
		text-decoration: none;
		border: 1px solid rgba(255, 84, 2, 0.45);
		padding: 0.45rem 1.1rem;
		transition: background 0.2s, border-color 0.2s, color 0.2s;
	}
	.nav-cta:hover {
		background: rgba(255, 84, 2, 0.06);
		border-color: var(--orange);
		color: var(--orange);
	}

	/* ── Hero body ───────────────────────────── */
	.hero-body {
		padding: 10vh 0 7rem;
	}

	.eyebrow {
		font-family: var(--font-display);
		font-size: 0.85rem;
		letter-spacing: 0.3em;
		color: var(--sky);
		margin-bottom: 2.5rem;
		font-weight: 700;
	}

	/* Headline */
	.display-h1 {
		font-family: var(--font-headline);
		font-weight: 700;
		font-size: clamp(3rem, 5vw, 5rem);
		line-height: 1.0;
		letter-spacing: -0.02em;
		margin: 0 0 4rem;
		color: var(--black);
		display: flex;
		flex-direction: column;
	}

	.line { display: block; }

	/* "STORY." accent in forest green */
	.display-h1 em {
		font-style: normal;
		color: var(--sky);
	}

	/* Slight indent — editorial asymmetry */
	.line-3 { padding-left: 0.05em; }
	.line-4 { padding-left: 0.05em; }

	.hero-sub {
		font-family: var(--font-body);
		font-size: 1rem;
		font-weight: 400;
		color: rgba(25, 21, 20, 0.72);
		line-height: 1.7;
		max-width: 440px;
		margin-bottom: 3.5rem;
	}

	.hero-cta {
		font-family: var(--font-display);
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--black);
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		border-bottom: 1px solid rgba(255, 84, 2, 0.4);
		padding-bottom: 4px;
		transition: color 0.2s, border-color 0.2s;
	}
	.hero-cta:hover {
		color: var(--orange);
		border-color: var(--orange);
	}

	/* Thin rule at very bottom — grounds the hero */
	.hero-scroll-rule {
		position: absolute;
		bottom: 0;
		left: 3rem;
		right: 3rem;
		height: 1px;
		background: rgba(25, 21, 20, 0.08);
	}

	/* ── Responsive ──────────────────────────── */
	@media (max-width: 768px) {
		.hero-body { padding: 5vh 0 4rem; }
		.display-h1 { font-size: clamp(3rem, 12vw, 5rem); margin-bottom: 2rem; }
		.hero-sub { font-size: 0.95rem; max-width: 100%; }
		.hero-scroll-rule { left: 1.5rem; right: 1.5rem; }
	}

	@media (max-width: 480px) {
		.hero-body { padding: 4vh 0 3rem; }
		.display-h1 { font-size: clamp(2.6rem, 11vw, 3.5rem); margin-bottom: 1.75rem; }
		.hero-sub { font-size: 0.9rem; margin-bottom: 2.5rem; }
		.eyebrow { margin-bottom: 1.75rem; }
	}
</style>
