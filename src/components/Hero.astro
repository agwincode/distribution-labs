---
---

<section id="hero" class="hero">

	<!-- Atmospheric sky glow, top-right -->
	<div class="hero-glow" aria-hidden="true"></div>
	<!-- Warm orange graze, bottom-left -->
	<div class="hero-glow-warm" aria-hidden="true"></div>

	<div class="container">

		<nav class="nav">
			<span class="wordmark">DISTRIBUTION LABS</span>
			<div class="nav-right">
				<a href="#offerings" class="nav-link">Work</a>
				<a href="#about" class="nav-link">About</a>
				<a href="#contact" class="nav-cta">Book a Session</a>
			</div>
		</nav>

		<div class="hero-body reveal">

			<p class="eyebrow">— OPERATOR ADVISORY</p>

			<h1 class="display-h1">
				<span class="line line-1">YOUR PRODUCT</span>
				<span class="line line-2">IS AHEAD OF</span>
				<span class="line line-3">YOUR <em>STORY.</em></span>
			</h1>

			<p class="hero-sub">
				That gap costs deals. We work with Series A through C founders to close it
				before a better-funded competitor defines the category for you.
			</p>

			<a href="#offerings" class="hero-cta">
				See the engagements
				<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
					<path d="M8 3v10M3 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
			</a>

		</div>
	</div>

	<div class="hero-scroll-rule" aria-hidden="true"></div>

</section>

<style>
	.hero {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		background: var(--black);
		position: relative;
		overflow: hidden;
	}

	/* Atmospheric glows */
	.hero-glow {
		position: absolute;
		top: -15%;
		right: -5%;
		width: 65vw;
		height: 65vw;
		background: radial-gradient(circle at center, var(--sky) 0%, transparent 60%);
		opacity: 0.055;
		filter: blur(90px);
		pointer-events: none;
		z-index: 0;
	}
	.hero-glow-warm {
		position: absolute;
		bottom: 0;
		left: -10%;
		width: 45vw;
		height: 45vw;
		background: radial-gradient(circle at center, var(--orange) 0%, transparent 65%);
		opacity: 0.035;
		filter: blur(100px);
		pointer-events: none;
		z-index: 0;
	}

	.container { position: relative; z-index: 1; }

	/* ── Nav ─────────────────────────────────── */
	.nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 2.25rem 0;
	}

	.wordmark {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 0.85rem;
		letter-spacing: 0.28em;
		color: var(--white);
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 2.5rem;
	}

	.nav-link {
		font-family: var(--font-body);
		font-size: 0.8rem;
		color: var(--muted);
		text-decoration: none;
		letter-spacing: 0.05em;
		transition: color 0.2s;
	}
	.nav-link:hover { color: var(--white); }

	.nav-cta {
		font-family: var(--font-body);
		font-size: 0.8rem;
		color: var(--white);
		text-decoration: none;
		letter-spacing: 0.05em;
		padding-bottom: 2px;
		border-bottom: 1px solid var(--orange);
		transition: color 0.2s;
	}
	.nav-cta:hover { color: var(--orange); }

	/* ── Hero body ───────────────────────────── */
	.hero-body {
		padding: 10vh 0 7rem;
	}

	.eyebrow {
		font-family: var(--font-display);
		font-size: 0.72rem;
		letter-spacing: 0.3em;
		color: var(--muted);
		margin-bottom: 2.5rem;
		font-weight: 400;
	}

	/* Massive condensed headline */
	.display-h1 {
		font-family: var(--font-display);
		font-weight: 900;
		font-size: clamp(5.5rem, 11vw, 9.5rem);
		line-height: 0.91;
		letter-spacing: -0.01em;
		text-transform: uppercase;
		margin: 0 0 4rem;
		color: var(--white);
		display: flex;
		flex-direction: column;
	}

	.line { display: block; }

	/* "STORY." accent in sky blue */
	.display-h1 em {
		font-style: normal;
		color: var(--sky);
	}

	/* Slight indent on last line — editorial asymmetry */
	.line-3 { padding-left: 0.05em; }

	.hero-sub {
		font-family: var(--font-body);
		font-size: 1rem;
		font-weight: 400;
		color: var(--muted);
		line-height: 1.7;
		max-width: 440px;
		margin-bottom: 3.5rem;
	}

	.hero-cta {
		font-family: var(--font-display);
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--white);
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		border-bottom: 1px solid rgba(255, 84, 2, 0.5);
		padding-bottom: 4px;
		transition: color 0.2s, border-color 0.2s;
	}
	.hero-cta:hover {
		color: var(--orange);
		border-color: var(--orange);
	}

	/* Thin rule at very bottom — grounds the hero */
	.hero-scroll-rule {
		position: absolute;
		bottom: 0;
		left: 3rem;
		right: 3rem;
		height: 1px;
		background: var(--border);
	}

	/* ── Responsive ──────────────────────────── */
	@media (max-width: 1024px) {
		.display-h1 { font-size: clamp(4rem, 10vw, 7rem); }
	}

	@media (max-width: 768px) {
		.nav { flex-wrap: wrap; gap: 1.25rem; padding: 1.75rem 0; }
		.nav-right { gap: 1.5rem; }
		.hero-body { padding: 6vh 0 5rem; }
		.display-h1 { font-size: clamp(3.5rem, 13vw, 5.5rem); margin-bottom: 2.5rem; }
		.hero-sub { font-size: 0.95rem; }
		.hero-scroll-rule { left: 1.5rem; right: 1.5rem; }
	}

	@media (max-width: 480px) {
		.display-h1 { font-size: clamp(3rem, 14vw, 4rem); }
		.nav-link { display: none; }
	}
</style>
