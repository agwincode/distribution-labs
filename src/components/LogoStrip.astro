---
---

<section class="logo-strip reveal">
	<div class="container">

		<p class="strip-label">WHERE WE'VE BUILT</p>

		<div class="logo-row">
			<div class="logo-item">
				<img src="https://www.vectorlogo.zone/logos/asana/asana-ar21.svg" alt="Asana" class="logo-img" />
			</div>
			<div class="logo-item">
				<img src="https://upload.wikimedia.org/wikipedia/commons/8/8a/Carta-logo.svg" alt="Carta" class="logo-img" />
			</div>
			<div class="logo-item">
				<img src="https://www.vectorlogo.zone/logos/dropbox/dropbox-ar21.svg" alt="Dropbox" class="logo-img" />
			</div>
			<div class="logo-item">
				<img src="/logos/descript.svg" alt="Descript" class="logo-img" />
			</div>
			<div class="logo-item">
				<img src="/logos/opensea.svg" alt="OpenSea" class="logo-img" />
			</div>
		</div>

		<p class="strip-sub">The team that built marketing orgs at Asana, Dropbox, Carta, and more.</p>

	</div>
</section>

<style>
	/* ── Light section — stark contrast with dark hero ── */
	.logo-strip {
		background: var(--white);
		padding: 5.5rem 0;
	}

	.strip-label {
		font-family: var(--font-display);
		font-size: 0.65rem;
		font-weight: 700;
		letter-spacing: 0.28em;
		color: var(--muted);
		text-align: center;
		margin-bottom: 3.5rem;
	}

	.logo-row {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 5rem;
		flex-wrap: wrap;
		margin-bottom: 3.5rem;
	}

	.logo-item {
		display: flex;
		justify-content: center;
		align-items: center;
	}

	/* On light bg: brightness(0) renders logos as solid black */
	.logo-img {
		height: 36px;
		width: auto;
		max-width: 140px;
		filter: brightness(0);
		opacity: 0.55;
		transition: opacity 0.25s;
		object-fit: contain;
	}
	.logo-img:hover { opacity: 0.85; }

	.strip-sub {
		font-family: var(--font-body);
		font-size: 0.875rem;
		font-weight: 400;
		color: #7a6a70;
		text-align: center;
		margin: 0;
		letter-spacing: 0.01em;
	}

	@media (max-width: 768px) {
		.logo-strip { padding: 4rem 0; }
		.logo-row { gap: 2.5rem 3.5rem; }
		.logo-img { height: 28px; }
	}
</style>
