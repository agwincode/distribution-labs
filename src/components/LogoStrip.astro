---
---

<section class="logo-strip reveal">
	<div class="container">
		<p class="strip-label">WHERE WE'VE BUILT</p>
		<div class="logo-grid">
			<div class="logo-item">
				<img src="https://www.vectorlogo.zone/logos/asana/asana-ar21.svg" alt="Asana" class="logo-img" />
			</div>
			<div class="logo-item">
				<img src="https://upload.wikimedia.org/wikipedia/commons/8/8a/Carta-logo.svg" alt="Carta" class="logo-img" />
			</div>
			<div class="logo-item">
				<img src="https://www.vectorlogo.zone/logos/dropbox/dropbox-ar21.svg" alt="Dropbox" class="logo-img" />
			</div>
			<div class="logo-item">
				<img src="/logos/descript.svg" alt="Descript" class="logo-img logo-no-invert" />
			</div>
			<div class="logo-item">
				<img src="/logos/opensea.svg" alt="OpenSea" class="logo-img logo-no-invert" />
			</div>
		</div>
		<p class="strip-subtext">The team that built marketing orgs at Asana, Dropbox, Carta, and more.</p>
	</div>
</section>

<style>
	.logo-strip {
		padding: 6rem 0;
		background: rgba(255, 255, 255, 0.02);
		border-top: 1px solid var(--border-dim);
		border-bottom: 1px solid var(--border-dim);
	}
	.strip-label {
		font-size: 0.75rem;
		letter-spacing: 0.2rem;
		color: var(--p-orange);
		text-align: center;
		margin-bottom: 4rem;
		font-weight: 600;
	}
	.logo-grid {
		display: flex;
		justify-content: center;
		align-items: center;
		opacity: 0.9;
		gap: 5rem; 
		margin-bottom: 4rem;
		flex-wrap: wrap; /* Smarter mobile distribution */
	}
	.logo-item {
		flex: 0 1 auto;
		display: flex;
		justify-content: center;
		align-items: center;
		min-width: 180px;
	}
	.logo-img {
		width: auto;
		max-width: 100%;
		filter: brightness(0) invert(1);
		transition: transform 0.3s;
		object-fit: contain;
	}
	.logo-no-invert {
		filter: none !important;
	}
	/* Optical Scaling */
	.logo-item:nth-child(1) .logo-img { height: 48px; }
	.logo-item:nth-child(2) .logo-img { height: 40px; }
	.logo-item:nth-child(3) .logo-img { height: 48px; }
	.logo-item:nth-child(4) .logo-img { height: 48px; }
	.logo-item:nth-child(5) .logo-img { height: 54px; }

	.logo-img:hover { transform: scale(1.05); }
	
	.strip-subtext {
		text-align: center;
		font-family: var(--font-serif);
		font-size: 1.1rem;
		color: var(--fg-muted);
		font-style: normal;
		max-width: 600px;
		margin: 0 auto;
	}


	@media (max-width: 968px) {
		.logo-grid { 
			gap: 2.5rem 3.5rem; 
			padding: 0 1.5rem; 
			justify-content: center;
		}
		.logo-item { 
			min-width: 100px;
			flex: 1 1 30%; 
		}
		.strip-label { margin-bottom: 3rem; padding: 0 1rem; }
		.strip-subtext { padding: 0 1.5rem; font-size: 1rem; line-height: 1.6; }
	}

	@media (max-width: 480px) {
		.logo-item { 
			flex: 1 1 40%; 
		}
		/* Mobile-specific Optical Scaling */
		.logo-item:nth-child(1) .logo-img { height: 32px; }
		.logo-item:nth-child(2) .logo-img { height: 26px; }
		.logo-item:nth-child(3) .logo-img { height: 32px; }
		.logo-item:nth-child(4) .logo-img { height: 32px; }
		.logo-item:nth-child(5) .logo-img { height: 36px; }
	}
</style>