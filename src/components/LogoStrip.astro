---
---

<section class="logo-strip reveal">
	<div class="container">
		<p class="strip-label">WHERE WE'VE BUILT</p>
		<div class="logo-row">
			<img src="/logos/carta.svg"     alt="Carta"                  class="logo logo-carta" />
			<img src="/logos/asana.svg"     alt="Asana"                  class="logo logo-lg" />
			<img src="/logos/descript-wordmark.svg"  alt="Descript"      class="logo logo-md" />
			<img src="/logos/opensea-wordmark.svg" alt="OpenSea"          class="logo logo-opensea" />
			<img src="/logos/dropbox.svg"   alt="Dropbox"                class="logo logo-xl" />
			<img src="/logos/invisible.svg" alt="Invisible Technologies" class="logo" />
		</div>
	</div>
</section>

<style>
	.logo-strip {
		background: var(--black);
		padding: 4rem 0 5rem;
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
	}

	.strip-label {
		font-family: var(--font-display);
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.28em;
		color: var(--orange);
		text-align: left;
		margin-bottom: 2.5rem;
	}

	.logo-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.logo {
		height: 22px;
		width: auto;
		opacity: 0.4;
		filter: brightness(0) invert(1);
		transition: opacity 0.3s;
	}

	/* Icon-only marks get taller so their visual weight matches wordmarks */
	.logo-icon { height: 36px; }
	.logo-icon.opensea { height: 40px; }
	/* Wordmarks that need a bit more presence */
	.logo-carta { height: 42px; }
	.logo-md { height: 31px; }
	.logo-opensea { height: 34px; }
	.logo-lg { height: 41px; }
	.logo-xl { height: 48px; }

	.logo:hover { opacity: 0.75; }

	@media (max-width: 760px) {
		.logo-row { justify-content: flex-start; gap: 0.75rem 1.25rem; }
		.logo { height: 16px; }
		.logo-carta { height: 22px; }
		.logo-md { height: 18px; }
		.logo-opensea { height: 20px; }
		.logo-lg { height: 24px; }
		.logo-xl { height: 28px; }
	}
</style>
