---
---

<section class="logo-strip reveal">
	<div class="container">
		<p class="strip-label">WHERE WE'VE BUILT</p>
		<div class="logo-row">
			<img src="/logos/carta.svg"     alt="Carta"                  class="logo logo-md" />
			<img src="/logos/asana.svg"     alt="Asana"                  class="logo logo-lg" />
			<img src="/logos/descript.svg"  alt="Descript"               class="logo logo-icon" />
			<img src="/logos/opensea.svg"   alt="OpenSea"                class="logo logo-icon" />
			<img src="/logos/dropbox.svg"   alt="Dropbox"                class="logo logo-xl" />
			<img src="/logos/invisible.svg" alt="Invisible Technologies" class="logo" />
		</div>
	</div>
</section>

<style>
	.logo-strip {
		background: var(--black);
		padding: 4rem 0 5rem;
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
	}

	.strip-label {
		font-family: var(--font-display);
		font-size: 0.65rem;
		font-weight: 700;
		letter-spacing: 0.28em;
		color: var(--orange);
		text-align: left;
		margin-bottom: 2.5rem;
	}

	.logo-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 2rem;
	}

	.logo {
		height: 22px;
		width: auto;
		opacity: 0.4;
		filter: brightness(0) invert(1);
		transition: opacity 0.3s;
	}

	/* Icon-only marks get taller so their visual weight matches wordmarks */
	.logo-icon { height: 36px; }
	.logo-icon.opensea { height: 40px; }
	/* Wordmarks that need a bit more presence */
	.logo-md { height: 31px; }   /* carta +20%+20% */
	.logo-lg { height: 38px; }   /* asana +30%+30% */
	.logo-xl { height: 46px; }   /* dropbox +30%+20%+30% */

	.logo:hover { opacity: 0.75; }

	@media (max-width: 768px) {
		.logo-row { justify-content: flex-start; gap: 2rem 2.5rem; }
		.logo { height: 18px; }
		.logo-icon { height: 28px; }
	}
</style>
