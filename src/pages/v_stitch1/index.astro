---
// v_stitch1 - Home Page (Official Brand Alignment)
---
<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital,wght@0,400;1,400&family=Instrument+Sans:wght@400;600;700&family=Space+Mono&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

    <script is:inline src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    
    <script is:inline>
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "background": "#edece3", // Official Surface (Off White)
              "deep-authority": "#191514", // Official Base (Warm Black)
              "strategic-action": "#ff5402", // Official Action (Orange)
              "technical-sky": "#a2a1f8", // Official AI Accent (Sky)
              "muted-gray": "#a38c97", // Official Muted (Gray)
              "surface-container-high": "#e5e4d9", // Slightly darker than surface for contrast
            },
            fontFamily: {
              "headline": ["Instrument Serif", "serif"],
              "body": ["Instrument Sans", "sans-serif"],
              "mono": ["Space Mono", "monospace"]
            },
            borderRadius: {"DEFAULT": "12px", "lg": "12px", "xl": "12px", "full": "9999px"},
          },
        },
      }
    </script>
    
    <style is:inline>
        body {
            background-color: #edece3 !important;
            color: #191514 !important;
            font-family: 'Instrument Sans', sans-serif;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
            font-size: 18px;
        }
        .technical-overshoot {
            position: relative;
        }
        .technical-overshoot::before, .technical-overshoot::after {
            content: '';
            position: absolute;
            background: #191514;
            opacity: 0.2;
        }
        .overshoot-tr::before { top: -2px; right: 0; width: 1px; height: 10px; }
        .overshoot-tr::after { top: 0; right: -2px; width: 10px; height: 1px; }
        
        .dot-grid {
            background-image: radial-gradient(#191514 0.5px, transparent 0.5px);
            background-size: 24px 24px;
            opacity: 0.05;
        }
        
        .architect-shadow {
            transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
        }
        .architect-shadow:hover {
            transform: translate(-2px, -2px);
            box-shadow: 4px 4px 0px #191514;
        }

        h1, h2, h3, h4 {
            font-family: 'Instrument Serif', serif;
            letter-spacing: 0.02em;
        }
    </style>
    <title>Growth Engineered to Inflect | AI Advisory</title>
</head>
<body class="bg-background text-deep-authority selection:bg-technical-sky/30">
<!-- TopNavBar Shell -->
<nav class="bg-background border-b-[0.5px] border-deep-authority/10 flex justify-between items-center w-full px-8 md:px-12 py-5 max-w-[1920px] mx-auto fixed top-0 z-50">
    <div class="text-xl font-bold tracking-tighter uppercase font-mono text-deep-authority">
        <a href="/v_stitch1">AI ADVISORY</a>
    </div>
    <div class="hidden md:flex items-center space-x-10">
        <a class="text-deep-authority font-mono text-[12px] opacity-70 hover:text-strategic-action hover:opacity-100 transition-all duration-200 uppercase tracking-wider" href="/v_stitch1/perspectives">Perspectives</a>
        <a class="text-deep-authority font-mono text-[12px] opacity-70 hover:text-strategic-action hover:opacity-100 transition-all duration-200 uppercase tracking-wider" href="/v_stitch1/intelligence">Intelligence</a>
        <a class="text-deep-authority font-mono text-[12px] opacity-70 hover:text-strategic-action hover:opacity-100 transition-all duration-200 uppercase tracking-wider" href="#">Methodology</a>
        <a class="text-deep-authority font-mono text-[12px] opacity-70 hover:text-strategic-action hover:opacity-100 transition-all duration-200 uppercase tracking-wider" href="#">Archive</a>
    </div>
    <button class="bg-deep-authority text-background px-6 py-2.5 font-mono text-[12px] uppercase tracking-wider architect-shadow rounded-none">
        Contact Us
    </button>
</nav>

<main class="pt-24 min-h-screen">
    <!-- Hero Section: The Architect's Grid -->
    <section class="relative px-8 md:px-12 py-20 md:py-32 grid grid-cols-12 gap-8 items-end border-b border-deep-authority/5">
