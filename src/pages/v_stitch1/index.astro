                        <div class="w-2.5 h-2.5 bg-muted-gray rounded-full opacity-30"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Technical Annotation Section -->
    <section class="px-8 md:px-12 py-24 md:py-32 bg-surface-container-high/20 grid grid-cols-12 gap-12 items-center border-y border-deep-authority/5">
        <div class="col-span-12 md:col-span-5">
