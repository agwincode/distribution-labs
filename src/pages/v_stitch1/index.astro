                <h4 class="text-3xl italic font-normal leading-snug">Real-time risk mapping for global entities.</h4>
                <span class="material-symbols-outlined text-strategic-action text-3xl">token</span>
            </div>
            <!-- Medium Feature Card -->
            <div class="col-span-12 md:col-span-8 bg-surface-container-high/30 p-10 md:p-14 border border-deep-authority/5 flex flex-col md:flex-row gap-12 items-center">
                <div class="w-full md:w-1/2">
                    <img class="w-full h-72 object-cover grayscale brightness-90 border border-deep-authority/10 rounded-lg" alt="Macro photo of server motherboard" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCV0maNwxNgeki22IDN8SZoh8xoyL36XTsBl4LeRoS8HtpHpaHtaU0LxK3rVJwvIMIWpT1uhg5VCW0qoc09eh3RwFYL7jQr2ZxCW_Y__2z5RHiYOH97A7aeFNzhPNslZ6RZq4fP-_1UsqZqY8NsJnn80dEz0NdJbjCPoqVaSTbU9Hw4s596UXzMBZ1vmK54BCJKiIs2DlxI8u9NOjAHfk-lF1Z4LJ_g88t7y5RRs5G4MBGRz-LwCGdRv_JTLwY488faGkC-Ss2TBTBN"/>
                </div>
                <div class="w-full md:w-1/2">
                    <span class="font-mono text-[11px] text-technical-sky uppercase tracking-widest mb-4 block font-bold">System Status: Active</span>
