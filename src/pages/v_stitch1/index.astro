        <div class="col-span-12 md:col-span-6 md:col-start-7">
            <h2 class="text-5xl md:text-6xl font-bold mb-10 tracking-tight">Precise Humanism.</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                <div class="space-y-5">
                    <p class="font-mono text-[12px] text-technical-sky uppercase tracking-[0.3em] font-bold">01 / Intentional Design</p>
                    <p class="text-lg text-deep-authority/70 leading-relaxed font-serif italic">
