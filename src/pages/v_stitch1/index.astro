                        <span class="border-b border-deep-authority/20 pb-1">View Case Study</span>
                        <span class="material-symbols-outlined group-hover:translate-x-2 transition-transform">arrow_right_alt</span>
                    </button>
                </div>
            </div>
            <!-- Small Technical Block -->
            <div class="col-span-12 md:col-span-4 bg-deep-authority text-background p-10 border border-deep-authority flex flex-col justify-between min-h-[320px] architect-shadow rounded-none">
