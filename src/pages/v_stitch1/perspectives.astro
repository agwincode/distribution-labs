<div class="fixed bottom-12 right-12 z-50">
    <button class="w-16 h-16 bg-strategic-action text-background shadow-2xl flex items-center justify-center group hover:bg-deep-authority transition-all">
        <span class="material-symbols-outlined text-2xl group-hover:rotate-45 transition-transform text-background">add</span>
