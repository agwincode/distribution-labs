                    <img class="w-full h-full object-cover grayscale opacity-50 mix-blend-multiply" alt="Abstract blueprint" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCwXMfe88hbfLWl3nxcjjTyzyMnVF5HTsSYlJn49f0bO9MqPQtVO9iFdOYwSxAZAVSnnW0bB87zJT_qS9IYlnws5qDEmhI0UrIaYkEDiUwh0cE4OMWYNdyuWeKjvD8AnNWoIfQeIS4ZuQ1qeiLh-wfsJHwxolvSxtBlSiULvzQl9-LQtkP7drssVH0MUdX6_D7wrUmz0r-6ksXH8NcQbR7xJqN-4Lt7SfEeEDuN2F3BeXODvdh2Y4-SCnjQSIIOjrX2q13aLFvdaHUa"/>
                </div>
