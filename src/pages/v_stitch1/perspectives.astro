            <ul class="space-y-4">
                <li><a class="font-mono text-[11px] uppercase tracking-[0.2em] text-muted-gray hover:text-technical-sky transition-colors font-bold" href="#">Technical Audits</a></li>
                <li><a class="font-mono text-[11px] uppercase tracking-[0.2em] text-muted-gray hover:text-technical-sky transition-colors font-bold" href="#">Operational AI</a></li>
