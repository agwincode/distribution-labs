                <h3 class="text-3xl tracking-tight text-deep-authority">Structural Bias in Prompt Engineering.</h3>
            </article>
        </div>
    </section>

    <!-- Journal Grid -->
    <section class="border-t-4 border-deep-authority pt-16">
