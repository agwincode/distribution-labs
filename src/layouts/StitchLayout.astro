---
interface Props {
	title: string;
	bodyClass?: string;
}

const { 
	title, 
	bodyClass = "bg-background text-deep-authority font-body selection:bg-technical-sky/30" 
} = Astro.props;
---

<!doctype html>
<html lang="en" class="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<!-- Proper Font Loading with correct weights -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital,wght@0,400;1,400&family=Instrument+Sans:wght@400;600;700&family=Space+Mono&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
		
		<title>{title}</title>
		
		<!-- Tailwind Config MUST come before the CDN script -->
		<script is:inline>
			window.tailwind = window.tailwind || {};
			tailwind.config = {
				darkMode: "class",
				theme: {
					extend: {
						colors: {
							"surface-container-low": "#f4f4ef",
							"on-primary-fixed": "#380c00",
							"tertiary": "#000000",
							"inverse-surface": "#2f312e",
							"on-secondary-fixed-variant": "#3e4373",
							"primary-fixed-dim": "#ffb59c",
							"background": "#fafaf5",
							"tertiary-container": "#1d1b19",
							"inverse-primary": "#ffb59c",
							"surface-container-high": "#e8e8e3",
							"error-container": "#ffdad6",
							"on-secondary": "#ffffff",
							"on-tertiary": "#ffffff",
							"on-primary": "#ffffff",
							"on-secondary-container": "#4c5081",
							"primary-container": "#380c00",
							"on-primary-fixed-variant": "#822800",
							"surface-container": "#eeeee9",
							"on-tertiary-fixed": "#1d1b19",
							"tertiary-fixed": "#e8e1dd",
							"surface-container-highest": "#e3e3de",
							"surface": "#fafaf5",
							"on-tertiary-fixed-variant": "#494643",
							"on-secondary-fixed": "#121645",
							"secondary": "#565a8c",
							"primary": "#000000",
							"outline-variant": "#cec5bd",
							"on-tertiary-container": "#888380",
							"outline": "#7d766f",
							"tertiary-fixed-dim": "#cbc5c2",
							"error": "#ba1a1a",
							"secondary-container": "#c1c5fe",
							"secondary-fixed": "#e0e0ff",
							"surface-container-lowest": "#ffffff",
							"on-error-container": "#93000a",
							"on-background": "#1a1c19",
							"surface-tint": "#a53c10",
							"inverse-on-surface": "#f1f1ec",
							"primary-fixed": "#ffdbcf",
							"on-surface": "#1a1c19",
							"on-error": "#ffffff",
							"on-primary-container": "#d76033",
							"surface-dim": "#dadad5",
							"surface-variant": "#e3e3de",
							"surface-bright": "#fafaf5",
							"on-surface-variant": "#4c4640",
							"secondary-fixed-dim": "#bec2fb",
							"deep-authority": "#12100E",
							"strategic-action": "#E66B3D",
							"technical-sky": "#B4B8F0"
						},
						fontFamily: {
							"headline": ["Instrument Serif", "serif"],
							"body": ["Instrument Sans", "sans-serif"],
							"mono": ["Space Mono", "monospace"],
							"serif": ["Instrument Serif", "serif"],
							"sans": ["Instrument Sans", "sans-serif"],
							"label": ["Space Grotesk", "sans-serif"],
							"mono-grotesk": ["Space Grotesk", "monospace"],
						},
						borderRadius: {"DEFAULT": "0px", "lg": "0px", "xl": "0px", "full": "9999px"},
					},
				},
			}
		</script>
		<!-- Added plugins query param -->
		<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
		
		<style is:global>
			:root {
				--deep-authority: #12100E;
				--strategic-action: #E66B3D;
				--technical-sky: #B4B8F0;
				--background: #fafaf5;
			}

			html {
				background-color: var(--background);
				scroll-behavior: smooth;
			}

			/* Global UI Fixes */
			.material-symbols-outlined {
				font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
				font-size: 18px;
				display: inline-block;
				vertical-align: middle;
			}

			.technical-overshoot {
				position: relative;
			}

			.technical-overshoot::before, .technical-overshoot::after {
				content: '';
				position: absolute;
				background: var(--deep-authority);
				opacity: 0.2;
			}

			.overshoot-tr::before { top: -2px; right: 0; width: 1px; height: 10px; }
			.overshoot-tr::after { top: 0; right: -2px; width: 10px; height: 1px; }
			
			.dot-grid {
				background-image: radial-gradient(var(--deep-authority) 0.5px, transparent 0.5px);
				background-size: 24px 24px;
				opacity: 0.05;
				position: absolute;
				inset: 0;
				pointer-events: none;
			}
			
			.architect-shadow {
				transition: all 0.2s ease;
			}

			.architect-shadow:hover {
				transform: translate(-2px, -2px);
				box-shadow: 2px 2px 0px var(--deep-authority);
			}

			.architect-card {
				transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
			}

			.architect-card:hover {
				transform: translate(-4px, -4px);
				box-shadow: 8px 8px 0px var(--deep-authority);
			}

			/* Grain Effect from Main Site */
			.grain-stitch {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				pointer-events: none;
				z-index: 99;
				opacity: 0.03;
				background-image: url('https://grainy-gradients.vercel.app/noise.svg');
			}
		</style>
	</head>
	<body class={bodyClass}>
		<div class="grain-stitch"></div>
		<slot />
	</body>
</html>
