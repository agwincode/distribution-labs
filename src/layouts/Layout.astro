---
interface Props {
	title: string;
	description?: string;
	ogImage?: string;
}

const {
	title,
	description = "Distribution Labs — Growth advisory for venture-backed founders.",
	ogImage = "https://distribution-labs.com/og.jpg",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="canonical" href={canonicalURL} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

		<!-- Primary -->
		<title>{title}</title>
		<meta name="description" content={description} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:site_name" content="Distribution Labs" />

		<!-- Twitter / X -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&family=Barlow:wght@300;400;500&family=DM+Serif+Display:ital@0;1&family=Playfair+Display:ital,wght@0,700;1,700&family=Fraunces:ital,opsz,wght@0,9..144,700;1,9..144,700&display=swap" rel="stylesheet">
	</head>
	<body class="distro-body">
		<div class="grain"></div>
		<slot />

		<script>
			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('active');

						// Stagger engagement rows
						if (entry.target.classList.contains('engagement-list')) {
							entry.target.querySelectorAll('.engagement-row').forEach((row, i) => {
								setTimeout(() => row.classList.add('active'), i * 130);
							});
						}
					}
				});
			}, { threshold: 0.08, rootMargin: '-5% 0px -5% 0px' });

			document.querySelectorAll('.reveal, .engagement-list').forEach(el => observer.observe(el));
		</script>
	</body>
</html>

<style is:global>
	:root {
		/* Core palette */
		--black:       #191514;
		--white:       #edece3;
		--muted:       #a38c97;
		--orange:      #ff5402;
		--sky:         #14513A;
		--green-dark:  #192b1e;

		/* Borders */
		--border:      rgba(237, 236, 227, 0.1);
		--border-light: rgba(25, 21, 20, 0.13);

		/* Typography */
		--font-display:  'Barlow Condensed', 'Arial Narrow', sans-serif;
		--font-body:     'Barlow', 'Helvetica Neue', sans-serif;
		--font-headline: 'Fraunces', Georgia, serif;

		/* Legacy aliases — keep older components working */
		--bg-charcoal: var(--black);
		--fg-white:    var(--white);
		--fg-muted:    var(--muted);
		--p-orange:    var(--orange);
		--p-sky:       var(--sky);
		--p-green:     #2D4D35;
		--p-olive:     #8A8E3D;
		--border-dim:  var(--border);
		--font-sans:   var(--font-body);
		--font-serif:  var(--font-display);
	}

	*, *::before, *::after { box-sizing: border-box; }

	html { scroll-behavior: smooth; }

	body.distro-body {
		background: var(--black);
		color: var(--white);
		font-family: var(--font-body);
		font-weight: 400;
		margin: 0;
		padding: 0;
		overflow-x: hidden;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	/* Film grain overlay */
	.grain {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: 9999;
	}
	.grain::after {
		content: '';
		position: absolute;
		inset: -50%;
		width: 200%;
		height: 200%;
		opacity: 0.032;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
		background-size: 180px 180px;
	}

	/* Layout container */
	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 3rem;
	}

	/* Scroll reveal */
	.reveal {
		opacity: 0;
		transform: translateY(22px);
		transition:
			opacity  0.85s cubic-bezier(0.16, 1, 0.3, 1),
			transform 0.85s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.reveal.active {
		opacity: 1;
		transform: translateY(0);
	}

	@media (max-width: 768px) {
		.container { padding: 0 1.5rem; }
	}
</style>
