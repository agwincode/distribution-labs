---
interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = "Distribution Labs — Operator advisory for venture-backed founders."
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body class="distro-body">
		<div class="grain"></div>
		<slot />

		<script>
			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('active');

						// Stagger engagement rows
						if (entry.target.classList.contains('engagement-list')) {
							entry.target.querySelectorAll('.engagement-row').forEach((row, i) => {
								setTimeout(() => row.classList.add('active'), i * 130);
							});
						}
					}
				});
			}, { threshold: 0.08, rootMargin: '-5% 0px -5% 0px' });

			document.querySelectorAll('.reveal, .engagement-list').forEach(el => observer.observe(el));
		</script>
	</body>
</html>

<style is:global>
	:root {
		/* Core palette */
		--black:       #191514;
		--white:       #edece3;
		--muted:       #a38c97;
		--orange:      #ff5402;
		--sky:         #a2a1f8;
		--green-dark:  #192b1e;

		/* Borders */
		--border:      rgba(237, 236, 227, 0.1);
		--border-light: rgba(25, 21, 20, 0.13);

		/* Typography */
		--font-display: 'Barlow Condensed', 'Arial Narrow', sans-serif;
		--font-body:    'Barlow', 'Helvetica Neue', sans-serif;

		/* Legacy aliases — keep older components working */
		--bg-charcoal: var(--black);
		--fg-white:    var(--white);
		--fg-muted:    var(--muted);
		--p-orange:    var(--orange);
		--p-sky:       var(--sky);
		--p-green:     #2D4D35;
		--p-olive:     #8A8E3D;
		--border-dim:  var(--border);
		--font-sans:   var(--font-body);
		--font-serif:  var(--font-display);
	}

	*, *::before, *::after { box-sizing: border-box; }

	html { scroll-behavior: smooth; }

	body.distro-body {
		background: var(--black);
		color: var(--white);
		font-family: var(--font-body);
		font-weight: 400;
		margin: 0;
		padding: 0;
		overflow-x: hidden;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	/* Film grain overlay */
	.grain {
		position: fixed;
		top: -50%;
		left: -50%;
		width: 200%;
		height: 200%;
		pointer-events: none;
		z-index: 9999;
		opacity: 0.032;
		background-image: url('https://grainy-gradients.vercel.app/noise.svg');
		background-size: 180px 180px;
	}

	/* Layout container */
	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 3rem;
	}

	/* Scroll reveal */
	.reveal {
		opacity: 0;
		transform: translateY(22px);
		transition:
			opacity  0.85s cubic-bezier(0.16, 1, 0.3, 1),
			transform 0.85s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.reveal.active {
		opacity: 1;
		transform: translateY(0);
	}

	@media (max-width: 768px) {
		.container { padding: 0 1.5rem; }
	}
</style>
